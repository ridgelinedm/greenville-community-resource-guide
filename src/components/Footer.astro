---
import { activeCategories, RESOURCES } from '../data/resources';
import { SITE_NAME, AREA } from '../consts';
import { link } from '../utils/url';
const cats = activeCategories();
const year = 2025; // build-time constant; update annually
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-about">
      <p class="footer-brand">{SITE_NAME}</p>
      <p class="footer-tag">
        A free directory connecting neighbors in {AREA} to {RESOURCES.length} trusted
        organizations for food, housing, health care, and more.
      </p>
      <a href={link('/get-help-now')} class="btn btn-outline footer-help">Need help now?</a>
    </div>

    <nav class="footer-col" aria-label="Browse by category">
      <h2 class="footer-h">Browse by need</h2>
      <ul>
        {
          cats
            .filter((c) => c.core)
            .map((c) => (
              <li>
                <a href={link(`/${c.slug}`)}>{c.label}</a>
              </li>
            ))
        }
        <li><a href={link('/resources')}>All resources (A–Z)</a></li>
      </ul>
    </nav>

    <nav class="footer-col" aria-label="More services">
      <h2 class="footer-h">More services</h2>
      <ul>
        {
          cats
            .filter((c) => !c.core)
            .slice(0, 10)
            .map((c) => (
              <li>
                <a href={link(`/${c.slug}`)}>{c.label}</a>
              </li>
            ))
        }
      </ul>
    </nav>

    <nav class="footer-col" aria-label="About this guide">
      <h2 class="footer-h">About</h2>
      <ul>
        <li><a href={link('/about')}>About this guide</a></li>
        <li><a href={link('/get-help-now')}>Emergency help</a></li>
        <li><a href={link('/resources')}>Search resources</a></li>
      </ul>
    </nav>
  </div>

  <div class="container footer-bottom">
    <p>
      © {year} {SITE_NAME}. This guide is provided for informational purposes. Always call
      ahead to confirm hours, eligibility, and availability — services can change. In an
      emergency, call <a href="tel:911">911</a>.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--blue-900);
    color: #cdd9e3;
    margin-top: auto;
    padding-block: 3rem 1.5rem;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 2.5rem;
  }
  .footer-brand {
    font-weight: 800;
    color: #fff;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }
  .footer-tag {
    font-size: 0.95rem;
    line-height: 1.55;
    color: #aebecb;
    max-width: 34ch;
  }
  .footer-help {
    margin-top: 1.1rem;
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.3);
  }
  .footer-help:hover {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.55);
  }
  .footer-h {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sage-300);
    margin-bottom: 0.9rem;
    font-weight: 700;
  }
  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
  }
  .footer-col a {
    color: #cdd9e3;
    text-decoration: none;
    font-size: 0.95rem;
  }
  .footer-col a:hover {
    color: #fff;
    text-decoration: underline;
  }
  .footer-bottom {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }
  .footer-bottom p {
    font-size: 0.85rem;
    color: #93a4b3;
    line-height: 1.6;
  }
  .footer-bottom a {
    color: #cdd9e3;
  }
  @media (max-width: 820px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer-about {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
