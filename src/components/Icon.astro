const dim = typeof size === 'number' ? `${size}` : size;
const a11y = label ? { role: 'img', 'aria-label': label } : { 'aria-hidden': 'true' };
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={dim}
  height={dim}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.9"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cls}
