---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import CategoryCard from '../components/CategoryCard.astro';
import CrisisLines from '../components/CrisisLines.astro';
import {
  CORE_CATEGORIES,
  CATEGORIES,
  countInCategory,
  RESOURCES,
  validIntents,
} from '../data/resources';
import { SITE_NAME, SITE_DESCRIPTION, AREA } from '../consts';
import { link, absolute } from '../utils/url';

const additional = CATEGORIES.filter((c) => !c.core && countInCategory(c.key) > 0);

const situations = [
  { slug: 'veterans', label: 'Veterans', icon: 'veterans' },
  { slug: 'families', label: 'Families with children', icon: 'family' },
  { slug: 'youth', label: 'Youth & young adults', icon: 'youth' },
  { slug: 'domestic-violence', label: 'Domestic violence', icon: 'shield' },
  { slug: 'reentry', label: 'Returning from prison/jail', icon: 'reentry' },
  { slug: 'seniors', label: 'Seniors', icon: 'heart' },
  { slug: 'lgbtq', label: 'LGBTQ+', icon: 'heart' },
  { slug: 'spanish-speaking', label: 'Se habla español', icon: 'immigrant' },
];

// Hand-picked intent pages to surface as "popular searches". Each is filtered
// against the actually-generated intent pages so a link can never 404.
const validKeys = new Set(validIntents().map((i) => `${i.category.slug}/${i.audience.slug}`));
const popular = (
  [
    ['food-assistance/families', 'Food assistance for families'],
    ['housing-shelter/domestic-violence', 'Emergency shelter for domestic violence'],
    ['medical-care/hiv', 'HIV testing & care'],
    ['mental-health-recovery/substance-use', 'Substance-use recovery'],
    ['housing-shelter/veterans', 'Housing help for veterans'],
    ['food-assistance/seniors', 'Food assistance for seniors'],
    ['housing-shelter/youth', 'Shelter for youth & young adults'],
    ['housing-shelter/no-id', 'Help without a photo ID'],
    ['financial-assistance/families', 'Rent & utility help for families'],
    ['medical-care/reentry', 'Health care after incarceration'],
  ] as [string, string][]
)
  .filter(([key]) => validKeys.has(key))
  .slice(0, 8)
  .map(([key, label]) => ({ href: `/${key}`, label }));

const origin = Astro.site?.origin ?? '';
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE_NAME,
    url: absolute(origin, '/'),
    description: SITE_DESCRIPTION,
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: absolute(origin, '/resources?q={search_term_string}'),
      },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE_NAME,
    url: absolute(origin, '/'),
    description: SITE_DESCRIPTION,
    areaServed: { '@type': 'AdministrativeArea', name: AREA },
  },
];
---

<Base title={`Free Help in Greenville, SC — Food, Housing, Health & More`} bareTitle jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow hero-eyebrow">
        <Icon name="map-pin" size={15} /> {AREA}
      </p>
      <h1>You deserve help. Let's find it together.</h1>
      <p class="lead hero-lead">
        A free, friendly guide to {RESOURCES.length} trusted organizations in Greenville
        offering food, shelter, health care, and support — for whatever you're facing right now.
      </p>

      <form class="searchbar" action={link('/resources')} method="get" role="search">
        <label for="hero-q" class="sr-only">Search resources</label>
        <Icon name="search" size={22} class="searchbar-icon" />
        <input
          id="hero-q"
          name="q"
          type="search"
          placeholder="Search your situation — e.g. “food for my family”, “shelter tonight”"
          autocomplete="off"
        />
        <button type="submit" class="btn btn-primary">Search</button>
      </form>

      <p class="hero-trust">
        <Icon name="check" size={16} /> No login &nbsp;·&nbsp;
        <Icon name="check" size={16} /> No cost &nbsp;·&nbsp;
        <Icon name="check" size={16} /> Confidential
      </p>

      <p class="hero-emergency">
        In immediate danger? Call <a href="tel:911">911</a>. In crisis? Call or text
        <a href="tel:988">988</a> — or see <a href={link('/get-help-now')}>get help now</a>.
      </p>
    </div>
  </section>

  <!-- Core categories -->
  <section class="section" aria-labelledby="needs-h">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Start here</p>
        <h2 id="needs-h">What do you need help with?</h2>
        <p>Choose a category to see every organization that can help, or search your exact situation above.</p>
      </div>
      <div class="home-cats">
        {CORE_CATEGORIES.map((c) => <CategoryCard category={c} count={countInCategory(c.key)} featured />)}
      </div>
    </div>
  </section>

  <!-- Browse by situation -->
  <section class="section-tight bg-sage" aria-labelledby="situation-h">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Built for your circumstances</p>
        <h2 id="situation-h">Find help for your situation</h2>
        <p>
          Every person's path is different. Tap who you are — we'll show the organizations
          most ready to help.
        </p>
      </div>
      <ul class="situation-list">
        {
          situations.map((s) => (
            <li>
              <a href={link(`/resources?audience=${s.slug}`)} class="situation-chip">
                <Icon name={s.icon} size={20} />
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="popular">
        <span class="popular-label">Popular pages:</span>
        {popular.map((p) => <a href={link(p.href)} class="popular-link">{p.label}</a>)}
      </div>
    </div>
  </section>

  <!-- Crisis lines -->
  <section class="section" aria-labelledby="crisis-h">
    <div class="container container-narrow">
      <h2 id="crisis-h" class="sr-only">Emergency hotlines</h2>
      <CrisisLines />
    </div>
  </section>

  <!-- More services -->
  <section class="section-tight bg-soft" aria-labelledby="more-h">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">More ways we can help</p>
        <h2 id="more-h">Additional services</h2>
      </div>
      <ul class="more-grid">
        {
          additional.map((c) => (
            <li>
              <a href={link(`/${c.slug}`)} class="more-card">
                <span class="more-icon"><Icon name={c.icon} size={20} /></span>
                <span>
                  <span class="more-label">{c.label}</span>
                  <span class="more-count">{countInCategory(c.key)} resources</span>
                </span>
                <Icon name="chevron-right" size={18} class="more-arrow" />
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Trust / how it works -->
  <section class="section" aria-labelledby="trust-h">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Why you can trust this guide</p>
        <h2 id="trust-h">Help that respects your dignity</h2>
      </div>
      <div class="grid grid-3 values">
        <div class="value">
          <span class="value-icon"><Icon name="heart" size={24} /></span>
          <h3>Free &amp; judgment-free</h3>
          <p>Every resource here is free or low-cost. Most welcome you with no paperwork, no proof of income, and no questions about your status.</p>
        </div>
        <div class="value">
          <span class="value-icon"><Icon name="shield" size={24} /></span>
          <h3>Local &amp; verified</h3>
          <p>These are real organizations serving Greenville County right now — with phone numbers, addresses, and who they serve, all in one place.</p>
        </div>
        <div class="value">
          <span class="value-icon"><Icon name="users" size={24} /></span>
          <h3>For everyone</h3>
          <p>Whatever your situation — veteran, parent, youth, in recovery, or starting over — there's a page and a person ready to help.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="section-tight">
    <div class="container">
      <div class="cta-band">
        <div>
          <h2>Not sure where to start?</h2>
          <p>Call <strong>211</strong> any time to talk with a real person who can point you to the right help — free and confidential.</p>
        </div>
        <div class="cta-actions">
          <a href="tel:211" class="btn btn-sage"><Icon name="phone" size={18} /> Call 211</a>
          <a href={link('/resources')} class="btn btn-outline">Browse all resources</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    background:
      radial-gradient(1100px 460px at 75% -10%, rgba(111, 156, 128, 0.16), transparent 60%),
      radial-gradient(900px 420px at 8% 0%, rgba(35, 93, 130, 0.12), transparent 55%),
      var(--bg-soft);
    border-bottom: 1px solid var(--line);
  }
  .hero-inner {
    padding-block: clamp(3rem, 2rem + 6vw, 5.5rem);
    max-width: 880px;
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--sage-700);
    margin-bottom: 0.9rem;
  }
  .hero h1 {
    max-width: 16ch;
  }
  .hero-lead {
    margin-top: 1rem;
    max-width: 56ch;
  }
  .searchbar {
    margin-top: 1.8rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: #fff;
    border: 1.5px solid var(--line-strong);
    border-radius: var(--radius-full);
    padding: 0.45rem 0.45rem 0.45rem 1.1rem;
    box-shadow: var(--shadow);
    max-width: 680px;
  }
  .searchbar:focus-within {
    border-color: var(--blue-500);
    box-shadow: var(--shadow-md);
  }
  .searchbar-icon {
    color: var(--slate-light);
    flex: none;
  }
  .searchbar input {
    flex: 1;
    border: none;
    outline: none;
    font: inherit;
    font-size: 1.02rem;
    color: var(--ink);
    background: transparent;
    min-width: 0;
    padding: 0.55rem 0;
  }
  .searchbar .btn {
    flex: none;
  }
  .hero-trust {
    margin-top: 1.1rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem;
    color: var(--slate);
    font-size: 0.95rem;
    font-weight: 500;
  }
  .hero-trust :global(svg) {
    color: var(--sage-600);
    vertical-align: -2px;
  }
  .hero-emergency {
    margin-top: 1.4rem;
    font-size: 0.95rem;
    color: var(--slate);
    background: var(--white);
    border: 1px solid var(--line);
    border-left: 4px solid var(--alert);
    border-radius: var(--radius-sm);
    padding: 0.7rem 1rem;
    max-width: 680px;
  }
  .hero-emergency a {
    font-weight: 700;
  }

  .home-cats {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    justify-content: center;
  }
  .home-cats > :global(*) {
    flex: 1 1 290px;
    max-width: 360px;
  }

  .situation-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }
  .situation-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: #fff;
    border: 1px solid var(--sage-100);
    border-radius: var(--radius-full);
    padding: 0.7rem 1.15rem;
    text-decoration: none;
    color: var(--blue-900);
    font-weight: 600;
    box-shadow: var(--shadow-sm);
    transition: transform 0.12s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .situation-chip:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
    border-color: var(--sage-300);
    color: var(--blue-900);
  }
  .situation-chip :global(svg) {
    color: var(--sage-600);
  }
  .popular {
    margin-top: 1.6rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.9rem;
    font-size: 0.92rem;
  }
  .popular-label {
    font-weight: 700;
    color: var(--slate);
  }
  .popular-link {
    color: var(--blue-700);
    text-decoration: none;
    border-bottom: 1px dotted var(--blue-200);
  }
  .popular-link:hover {
    color: var(--blue-900);
    border-bottom-style: solid;
  }

  .more-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.75rem;
  }
  .more-card {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.9rem 1rem;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .more-card:hover {
    border-color: var(--sage-300);
    box-shadow: var(--shadow-sm);
  }
  .more-icon {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 11px;
    background: var(--sage-50);
    color: var(--sage-700);
    flex: none;
  }
  .more-label {
    display: block;
    font-weight: 700;
    color: var(--blue-900);
    line-height: 1.2;
  }
  .more-count {
    display: block;
    font-size: 0.82rem;
    color: var(--slate);
  }
  .more-arrow {
    margin-left: auto;
    color: var(--slate-light);
  }

  .values {
    gap: 1.5rem;
  }
  .value {
    padding: 1.6rem;
    border-radius: var(--radius-lg);
    background: #fff;
    border: 1px solid var(--line);
  }
  .value-icon {
    display: grid;
    place-items: center;
    width: 50px;
    height: 50px;
    border-radius: 14px;
    background: var(--blue-50);
    color: var(--blue-700);
    margin-bottom: 1rem;
  }
  .value h3 {
    margin-bottom: 0.4rem;
  }
  .value p {
    color: var(--slate);
    font-size: 0.98rem;
  }

  .cta-band {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    background: linear-gradient(135deg, var(--blue-800), var(--blue-700));
    color: #fff;
    border-radius: var(--radius-lg);
    padding: 2rem 2.25rem;
    box-shadow: var(--shadow-md);
  }
  .cta-band h2 {
    color: #fff;
  }
  .cta-band p {
    color: #d4e2ec;
    margin-top: 0.4rem;
    max-width: 46ch;
  }
  .cta-band strong {
    color: #fff;
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }
  .cta-band .btn-outline {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.35);
  }
  .cta-band .btn-outline:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
  }
</style>
