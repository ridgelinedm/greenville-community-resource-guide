---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CrisisLines from '../components/CrisisLines.astro';
import { CORE_CATEGORIES, countInCategory } from '../data/resources';
import { link } from '../utils/url';

const quick = [
  {
    slug: 'food-assistance',
    icon: 'food',
    title: 'I need food today',
    text: 'Soup kitchens and pantries with same-day meals and groceries.',
  },
  {
    slug: 'housing-shelter',
    icon: 'housing',
    title: 'I need shelter tonight',
    text: 'Emergency shelters and day shelters. Call early — beds fill fast.',
  },
  {
    slug: 'medical-care',
    icon: 'medical',
    title: 'I need medical care',
    text: 'Free clinics for the uninsured. No insurance required.',
  },
  {
    slug: 'mental-health-recovery',
    icon: 'mental-health',
    title: 'I need someone to talk to',
    text: 'Counseling, crisis support, and recovery help.',
  },
];

const title = 'Get Help Right Now — Greenville, SC';
const description =
  'Emergency hotlines and same-day help in Greenville County: shelter tonight, food today, crisis lines, and free clinics. Call now — help is available 24/7.';
---

<Base title={title} description={description}>
  <div class="container ghn-top">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Get help now' }]} />
  </div>

  <section class="ghn-hero">
    <div class="container container-narrow">
      <h1>Get help right now</h1>
      <p class="lead">
        You are not alone, and help is available today. If you are in immediate danger, call
        <a href="tel:911">911</a>. Otherwise, start with one of the hotlines below — they are free,
        confidential, and answered 24/7.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container container-narrow">
      <CrisisLines />
    </div>
  </section>

  <section class="section-tight bg-soft">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Same-day help</p>
        <h2>What do you need most right now?</h2>
      </div>
      <div class="grid grid-4">
        {
          quick.map((q) => (
            <a href={link(`/${q.slug}`)} class="quick-card">
              <span class="quick-icon"><Icon name={q.icon} size={26} /></span>
              <span class="quick-title">{q.title}</span>
              <span class="quick-text">{q.text}</span>
              <span class="quick-link">
                See resources <Icon name="arrow-right" size={16} />
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container container-narrow">
      <div class="help-211">
        <span class="help-211-icon"><Icon name="phone" size={26} /></span>
        <div>
          <h2>Not sure who to call?</h2>
          <p>
            Dial <a href="tel:211"><strong>211</strong></a> any time, day or night. A trained
            specialist will listen to your situation and connect you with the right local
            resources — for free.
          </p>
        </div>
        <a href="tel:211" class="btn btn-sage"><Icon name="phone" size={18} /> Call 211</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .ghn-top {
    padding-top: 1.25rem;
  }
  .ghn-hero {
    padding-block: 1.5rem 0.5rem;
  }
  .ghn-hero .lead {
    margin-top: 0.75rem;
  }
  .ghn-hero a {
    font-weight: 700;
  }
  .quick-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.4rem;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: var(--ink);
    height: 100%;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .quick-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--sage-300);
  }
  .quick-icon {
    display: grid;
    place-items: center;
    width: 54px;
    height: 54px;
    border-radius: 15px;
    background: var(--blue-50);
    color: var(--blue-700);
    margin-bottom: 0.3rem;
  }
  .quick-title {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--blue-900);
  }
  .quick-text {
    color: var(--slate);
    font-size: 0.92rem;
    flex: 1;
  }
  .quick-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--blue-700);
    font-weight: 600;
    font-size: 0.92rem;
    margin-top: 0.4rem;
  }
  .help-211 {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    background: var(--sage-50);
    border: 1px solid var(--sage-100);
    border-radius: var(--radius-lg);
    padding: 1.75rem 2rem;
  }
  .help-211-icon {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: var(--sage-600);
    color: #fff;
    flex: none;
  }
  .help-211 > div {
    flex: 1;
    min-width: 240px;
  }
  .help-211 h2 {
    font-size: 1.35rem;
  }
  .help-211 p {
    margin-top: 0.3rem;
    color: var(--slate);
  }
</style>
